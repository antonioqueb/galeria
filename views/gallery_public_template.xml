<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- =========================================================
         Layout Base Independiente
         ========================================================= -->
    <template id="gallery_layout_headless">
        &lt;!DOCTYPE html&gt;
        <html lang="es">
            <head>
                <meta charset="utf-8"/>
                <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1"/>
                <title t-esc="title or 'Galería de Placas'"/>

                <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&amp;family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&amp;family=JetBrains+Mono:wght@400;500;600&amp;display=swap" rel="stylesheet"/>
                <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css"/>

                <t t-call-assets="web.assets_frontend" t-js="false"/>

                <style>
                    body {
                        margin: 0;
                        padding: 0;
                        background-color: #0f0f10;
                        color: #e0e0e0;
                        font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
                        font-feature-settings: 'cv11' on, 'ss01' on, 'ss03' on;
                        -webkit-font-smoothing: antialiased;
                        -moz-osx-font-smoothing: grayscale;
                        overflow-x: hidden;
                    }
                    a {
                        text-decoration: none;
                    }
                    * {
                        -webkit-tap-highlight-color: transparent;
                    }
                    img {
                        display: block;
                        max-width: 100%;
                    }
                </style>
            </head>

            <body>
                <main>
                    <t t-out="0"/>
                </main>

                <t t-call-assets="web.assets_frontend" t-css="false"/>
            </body>
        </html>
    </template>


    <!-- =========================================================
         Vista Principal Pública
         ========================================================= -->
    <template id="gallery_public_view">
        <t t-call="galeria.gallery_layout_headless">
            <t t-set="title" t-value="share.name"/>

            <!-- DATA ISLAND -->
            <script>
                window.galleryRawData = <t t-out="json_data"/>;
            </script>

            <!-- Métricas calculadas inline -->
            <t t-set="avg_per_piece" t-value="(total_area / total_pieces) if total_pieces else 0"/>
            <t t-set="created_date_str" t-value="share.create_date.strftime('%d %b').replace('.', '') if share.create_date else ''"/>

            <div class="gallery-wrapper">

                <!-- =================================================
                     HEADER
                     ================================================= -->
                <header class="gallery-header">
                    <div class="header-content">

                        <div class="brand-area">
                            <button id="btn-back-gallery" class="btn-back" type="button" style="display: none;">
                                <i class="fa fa-arrow-left"></i>
                                <span class="btn-back-label">Volver</span>
                            </button>

                            <div class="brand">
                                <span class="brand-row">
                                    <img src="/galeria/static/description/logosom.png" alt="SOM" class="brand-logo"/>
                                    <span class="light">GALLERY</span>
                                </span>
                                <span class="brand-sub">
                                    Catálogo exclusivo de placas seleccionadas
                                </span>
                            </div>
                        </div>

                        <div class="header-actions">
                            <div class="client-pill">
                                <div class="avatar">
                                    <t t-if="share.partner_id.name">
                                        <t t-esc="share.partner_id.name[:1].upper()"/>
                                    </t>
                                    <t t-else="">C</t>
                                </div>
                                <div class="info">
                                    <span class="label">Cliente</span>
                                    <span class="name" t-esc="share.partner_id.name.title() if share.partner_id.name else ''"/>
                                </div>
                            </div>
                        </div>

                    </div>
                </header>


                <!-- =================================================
                     HERO — Premium Editorial
                     ================================================= -->
                <section class="gallery-hero">
                    <div class="hero-inner">

                        <div class="hero-badge">
                            Selección privada para este cliente
                        </div>

                        <h1 class="hero-title">
                            Material exclusivo para
                            <span class="client-highlight" t-esc="share.partner_id.name.title() if share.partner_id.name else ''"/>
                        </h1>

                        <div class="hero-meta">
                            <div class="meta-item">
                                <i class="fa fa-user-tie"></i>
                                <span class="meta-label">Ejecutivo</span>
                                <strong t-field="share.user_id.name"/>
                            </div>

                            <div class="meta-item">
                                <i class="fa fa-hashtag"></i>
                                <span class="meta-label">Referencia</span>
                                <strong t-field="share.name"/>
                            </div>
                        </div>

                    </div>
                </section>
                <!-- =================================================
                     GRID PRINCIPAL
                     ================================================= -->
                <div class="content-container" id="main-gallery-container">

                    <t t-foreach="grouped_images" t-as="category">
                        <div class="category-block" t-att-data-category="category">

                            <h2 class="category-title">
                                <span class="cat-name">
                                    <t t-esc="category"/>
                                </span>
                                <span class="cat-count">
                                    <t t-esc="len(grouped_images[category])"/> elementos
                                </span>
                                <span class="line"></span>
                            </h2>

                            <div class="bento-grid">
                                <t t-foreach="grouped_images[category]" t-as="img">

                                    <div t-attf-class="bento-item #{'bento-large' if img.get('is_large') else ''} #{'is-block' if img['type'] == 'block' else ''}"
                                         t-att-data-id="img['id']"
                                         t-att-data-type="img['type']"
                                         t-att-data-quant-id="img.get('quant_id')"
                                         t-att-data-lot-id="img.get('lot_id')"
                                         t-att-data-name="img.get('product_name', img.get('name'))"
                                         t-att-data-lot="(img.get('block_name') or img['id']) if img['type'] == 'block' else img['lot_name']"
                                         t-att-data-dims="img['dimensions']"
                                         t-att-data-area="img['area']"
                                         t-att-data-url="img['url']">

                                        <div class="bento-card">

                                            <div class="img-container">
                                                <img t-att-src="img['url']"
                                                     loading="lazy"
                                                     t-att-alt="img['lot_name']"/>

                                                <div class="selection-indicator">
                                                    <i class="fa fa-check"></i>
                                                </div>

                                                <t t-if="img['type'] == 'block'">
                                                    <span class="block-badge">
                                                        <i class="fa fa-layer-group"></i>
                                                        <span><t t-esc="img['count']"/> placas</span>
                                                    </span>
                                                </t>

                                                <t t-if="img['type'] != 'block'">
                                                    <span class="unique-badge">
                                                        <i class="fa fa-gem"></i>
                                                        Lote único
                                                    </span>
                                                </t>

                                                <div class="card-actions">
                                                    <t t-if="img['type'] == 'block'">
                                                        <button class="btn-expand open-block-btn"
                                                                type="button"
                                                                title="Ver contenido del bloque">
                                                            <i class="fa fa-folder-open"></i>
                                                        </button>
                                                    </t>

                                                    <t t-else="">
                                                        <button class="btn-expand lightbox-trigger"
                                                                type="button"
                                                                title="Ampliar">
                                                            <i class="fa fa-expand"></i>
                                                        </button>
                                                    </t>
                                                </div>
                                            </div>

                                            <div class="card-footer">
                                                <div class="info-text">
                                                    <span class="product-name"
                                                          t-esc="img.get('product_name', img.get('name'))"/>

                                                    <div class="meta">
                                                        <span class="lot">
                                                            <t t-esc="img['lot_name']"/>
                                                        </span>

                                                        <t t-if="img['type'] != 'block'">
                                                            <span class="sep">·</span>
                                                            <span class="dims" t-esc="img['dimensions']"/>
                                                        </t>
                                                    </div>

                                                    <span class="area-badge">
                                                        <t t-esc="img['area']"/> m²
                                                    </span>
                                                </div>

                                                <button class="btn-add-cart" type="button" aria-label="Apartar">
                                                    <i class="fa fa-check"></i>
                                                    <span class="sr-only">Apartar</span>
                                                </button>
                                            </div>

                                        </div>
                                    </div>

                                </t>
                            </div>

                        </div>
                    </t>

                    <div t-if="not grouped_images" class="empty-state">
                        <h1>Sin placas disponibles</h1>
                        <p>No hay imágenes disponibles en este momento.</p>
                    </div>

                </div>
            </div>


            <!-- =====================================================
                 LIGHTBOX
                 ===================================================== -->
            <div id="lightbox" class="lightbox">
                <button class="close-lightbox" type="button">&#215;</button>

                <div class="lightbox-content"
                     onmousemove="gallery.zoomImage(event)"
                     onmouseleave="gallery.resetZoom()">
                    <img id="lightbox-img" src="" alt="Vista ampliada"/>
                </div>

                <div class="lightbox-info">
                    <div class="info-piece">
                        <i class="fa fa-gem"></i>
                        <strong id="lb-info-name"></strong>
                    </div>

                    <div class="info-sep"></div>

                    <div class="info-piece">
                        <i class="fa fa-tag"></i>
                        <span id="lb-info-lot"></span>
                    </div>

                    <div class="info-sep"></div>

                    <div class="info-piece">
                        <i class="fa fa-ruler-combined"></i>
                        <span id="lb-info-dims"></span>
                    </div>

                    <div class="info-sep"></div>

                    <div class="info-piece">
                        <i class="fa fa-vector-square"></i>
                        <span id="lb-info-area"></span>
                    </div>
                </div>
            </div>


            <!-- =====================================================
                 CARRITO
                 ===================================================== -->
            <div id="cart-sidebar" class="cart-sidebar">

                <div class="cart-header">
                    <h3>
                        <i class="fa fa-shopping-bag"></i>
                        Mi carrito
                    </h3>
                    <button class="close-cart" type="button">&#215;</button>
                </div>

                <div class="cart-rules-mini">
                    <i class="fa fa-clock"></i>
                    <span>Apartado temporal por <strong>5 días calendario</strong></span>
                </div>

                <div class="cart-items" id="cart-items-container"></div>

                <div class="cart-footer">
                    <div class="totals">
                        <div class="row">
                            <span>Placas:</span>
                            <strong id="total-plates">0</strong>
                        </div>

                        <div class="row highlight">
                            <span>Total m²:</span>
                            <strong id="total-area">0.00 m²</strong>
                        </div>
                    </div>

                    <div class="expiry-note">
                        <i class="fa fa-triangle-exclamation"></i>
                        <span>Al confirmar, las placas se retienen temporalmente.</span>
                    </div>

                    <button id="btn-confirm" class="btn-checkout" type="button">
                        <i class="fa fa-lock"></i>
                        Confirmar reserva
                    </button>
                </div>

            </div>

            <div id="cart-overlay" class="cart-overlay"></div>


            <!-- =====================================================
                 STICKY CTA MÓVIL
                 ===================================================== -->
            <div id="sticky-cart-bar" class="sticky-cart-bar visible">
                <div class="summary">
                    <span class="label">Carrito</span>
                    <span class="value">
                        <strong id="sticky-count">0</strong> placas ·
                        <strong id="sticky-area">0.00</strong> m²
                    </span>
                </div>

                <button id="sticky-open-cart" class="btn-open-cart" type="button">
                    <i class="fa fa-shopping-bag"></i>
                    Finalizar apartado
                </button>
            </div>


            <!-- =====================================================
                 CONTACTO WHATSAPP
                 ===================================================== -->
            <div class="contact-fab" t-if="share.salesperson_whatsapp_url">
                <a class="fab-button"
                   t-att-href="share.salesperson_whatsapp_url"
                   target="_blank"
                   rel="noopener noreferrer"
                   aria-label="Contactar por WhatsApp">
                    <i class="fa-brands fa-whatsapp"></i>
                </a>

                <div class="fab-tooltip">
                    Contactar a <strong t-esc="share.user_id.name"/>
                </div>
            </div>

        </t>
    </template>


    <!-- =========================================================
         Error: No encontrado
         ========================================================= -->
    <template id="gallery_not_found">
        <t t-call="galeria.gallery_layout_headless">
            <div class="error-page">
                <h1>404</h1>
                <p>Catálogo no encontrado</p>
            </div>
        </t>
    </template>


    <!-- =========================================================
         Error: Expirado
         ========================================================= -->
    <template id="gallery_expired">
        <t t-call="galeria.gallery_layout_headless">
            <div class="error-page">
                <h1>Enlace expirado</h1>
                <p>Este catálogo ya no está disponible.</p>
            </div>
        </t>
    </template>

</odoo>